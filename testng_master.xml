<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">


<suite name="IPL Master Suite" thread-count="5">
	
	<listeners>
	  <listener class-name="utilities.ExtentReportManager" />
  </listeners>
  
  <test thread-count="5" name="Chrome">
	
		<parameter name="browser" value="chrome" />
		
		<groups>
	        <run>
	            <include name="smoke"/>
	            <include name="regression"/>
	        </run>
	    </groups>

		<classes>
		
			<class name="testCases.TC001_FooterLinks" />
			<class name="testCases.TC002_TeamDetailsTest"/>
			<class name="testCases.TC003_PointTableValidation" />
			<class name="testCases.TC004_SearchFunctionality" />

		</classes>
	</test>
	
	<test thread-count="5" name="Edge">

		<parameter name="browser" value="edge" />
		<groups>
	        <run>
	            <include name="smoke"/>
	            <include name="regression"/>
	        </run>
	    </groups>

		<classes>
		
			<class name="testCases.TC001_FooterLinks" />
			<class name="testCases.TC002_TeamDetailsTest" />
			<class name="testCases.TC003_PointTableValidation" />
			<class name="testCases.TC004_SearchFunctionality" />

		</classes>
	</test>

	<test thread-count="5" name="FireFox">

		<parameter name="browser" value="firefox" />
		
		<groups>
	        <run>
	            <include name="smoke"/>
	            <include name="regression"/>
	        </run>
	    </groups>

		<classes>
		
			<class name="testCases.TC001_FooterLinks" />
			<class name="testCases.TC002_TeamDetailsTest" />
			<class name="testCases.TC003_PointTableValidation" />
			<class name="testCases.TC004_SearchFunctionality" />

		</classes>
	</test>
	
	
	
</suite> 